NODE_ENV=development
PORT=3001
BASE_URL=https://your-domain.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# LLM provider: auto | openai | ollama
LLM_PROVIDER=auto

# OpenAI (opcional se usar somente Ollama)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Ollama local (gratuito)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_VISION_MODEL=

# ERP API (para respostas com dados reais de negocio)
ERP_API_BASE_URL=http://localhost/ERP/api
ERP_API_TOKEN=
